    <string name="section_about">About</string>
    <string name="about_version">Version %1$s</string>
    <string name="about_app_description">Pixel Info reads your device\'s hardware and software details — CPU, memory, battery, display, network, sensors, and camera — entirely on-device. There\'s no account, no backend, and no analytics or crash reporting; network, location, and Bluetooth permissions are only requested from the Network screen, and only used to show that data back to you.</string>
